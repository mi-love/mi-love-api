// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum gender {
  male
  female
  other
}

enum auth_provider {
  local
  google
  apple
}

enum post_visibility {
  public
  friends
}

enum file_provider {
  local
  cloudinary
}

enum file_type {
  image
  video
  document
}

enum transaction_type {
  credit
  debit
}

enum status_type {
  success
  failed
  pending
}

enum currency {
  USD
}

enum message_type {
  text
  file
  announcement
}

enum notification_type {
  message
  security
  system
  social
}

enum user_account_status {
  active
  suspended
  banned
  deleted
}

enum verification_status {
  pending
  approved
  rejected
}

enum verification_type {
  bvn
  nin
  passport
  drivers_license
  national_id
}

enum admin_role {
  super_admin
  moderator
  finance
}

enum subscription_status {
  pending
  active
  expired
  canceled
}

enum refund_status {
  pending
  processing
  completed
  failed
  rejected
}

enum notification_channel {
  in_app
  email
  sms
}

enum notification_target {
  all
  segment
  user
}

enum report_type {
  csv
  pdf
}

model blocked_users {
  id String @id @default(cuid())

  user         user?   @relation("user", fields: [userId], references: [id])
  blocked_user user?   @relation("blocked_user", fields: [blockedUserId], references: [id])
  reason       String?

  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
  userId        String?
  blockedUserId String?
}

model user {
  id                String     @id @default(cuid())
  email             String     @unique
  first_name        String
  last_name         String
  username          String     @unique
  password          String?
  emergency_contact String?
  bio               String?
  profile_picture   file?      @relation(fields: [fileId], references: [id])
  home_address      String?
  interests         interest[]
  phone_number      String?
  country           String?
  gender            gender?
  date_of_birth     DateTime?
  is_admin          Boolean    @default(false)
  admin_role        admin_role?
  account_status    user_account_status @default(active)
  is_verified       Boolean    @default(false)
  is_flagged        Boolean    @default(false)
  is_deleted        Boolean    @default(false)
  banned_at         DateTime?
  suspended_at      DateTime?
  deleted_at        DateTime?
  deleted_reason    String?
  last_login_at     DateTime?

  fcm_token String? @db.Text

  comments comment[] @relation("comment_user")

  auth_provider auth_provider @default(local)

  my_friends user[] @relation("friends")
  friends    user[] @relation("friends")

  created_at     DateTime        @default(now())
  updated_at     DateTime        @updatedAt
  posts          post[]          @relation("post_user")
  likes          post[]          @relation("post_likes")
  status         status[]
  reaction       reaction[]
  liked_comments comment[]       @relation("liked_comments")
  fileId         String?
  blocked        blocked_users[] @relation("user")
  blocked_users  blocked_users[] @relation("blocked_user")
  wallet         wallet          @relation(fields: [walletId], references: [id])
  walletId       String
  transaction    transaction[]
  participant    participant[]
  message        message[]
  panic_actions  panic_actions[]
  notification   notification[]
  checkout_sessions checkout_session[]
  profile        profile?
  verifications  verification[]
  sessions       session[]
  devices        device[]
  linked_accounts_as_source user_link[] @relation("source_user")
  linked_accounts_as_target user_link[] @relation("target_user")
  subscriptions  subscription[]
  refunds_requested refund[] @relation("refund_requested_by")
  admin_logs     admin_action_log[] @relation("admin_actor")
  notification_logs notification_log[] @relation("notification_recipient")

  @@map("users")
}

model checkout_session {
  id        String   @id @default(cuid())
  amount    Float
  createdAt DateTime @default(now())
  userId    String
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("checkout_sessions")
}

model interest {
  id         String   @id @default(cuid())
  name       String   @unique
  // embeddings Unsupported("vector")?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  user       user[]

  @@map("interests")
}

model otp {
  id         String   @id @default(cuid())
  email      String
  otp        String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("otps")
}

model post {
  id      String @id @default(cuid())
  // embeddings Unsupported("vector")?
  content String @db.Text

  visibility post_visibility @default(public)
  files      file[]
  likes      user[]          @relation("post_likes")
  created_at DateTime        @default(now())
  updated_at DateTime        @updatedAt
  comments   comment[]
  userId     String
  user       user            @relation("post_user", fields: [userId], references: [id])

  @@map("posts")
}

model status {
  id       String     @id @default(cuid())
  user     user       @relation(fields: [userId], references: [id])
  content  String?    @db.VarChar()
  file     file[]
  reaction reaction[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  userId     String
}

model comment {
  id      String  @id @default(cuid())
  content String
  likes   user[]  @relation("liked_comments")
  user    user?   @relation("comment_user", fields: [userId], references: [id])
  userId  String?

  post   post?   @relation(fields: [postId], references: [id])
  postId String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("comments")
}

model file {
  id         String        @id @default(cuid())
  url        String
  provider   file_provider @default(local)
  created_at DateTime      @default(now())
  updated_at DateTime      @updatedAt
  type       file_type

  ref     String?
  post    post?     @relation(fields: [postId], references: [id])
  postId  String?
  status  status[]
  user    user[]
  gift    gift[]
  message message[]

  @@map("files")
}

model reaction {
  id         String   @id @default(cuid())
  emoji      String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  userId     String
  user       user     @relation(fields: [userId], references: [id])
  status     status?  @relation(fields: [statusId], references: [id])
  statusId   String?

  @@map("reactions")
}

model wallet {
  id         String   @id @default(cuid())
  balance    Decimal  @default(0) @db.Decimal(10, 2)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  user       user[]

  @@map("wallets")
}

model transaction {
  id           String           @id @default(cuid())
  amount       Float
  fee          Float?           @default(0)
  type         transaction_type
  description  String?
  status       status_type      @default(pending)
  currency     currency
  payment_link String?
  provider_ref String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  userId     String
  user       user     @relation(fields: [userId], references: [id])
  refunds    refund[]

  @@map("transactions")
}

model profile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        user     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio         String?  @db.Text
  photos      Json?
  preferences Json?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@map("profiles")
}

model verification {
  id           String              @id @default(cuid())
  userId       String
  user         user                @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         verification_type
  status       verification_status @default(pending)
  document_url String?
  metadata     Json?
  reason       String?
  reviewed_by  String?
  reviewed_at  DateTime?
  created_at   DateTime            @default(now())
  updated_at   DateTime            @updatedAt

  @@index([status])
  @@index([userId])
  @@map("verifications")
}

model session {
  id         String   @id @default(cuid())
  userId     String
  user       user     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token_hash String
  ip_address String?
  user_agent String?
  expires_at DateTime
  revoked_at DateTime?
  last_seen_at DateTime?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([userId])
  @@map("sessions")
}

model device {
  id         String   @id @default(cuid())
  userId     String
  user       user     @relation(fields: [userId], references: [id], onDelete: Cascade)
  device_id  String
  platform   String?
  os_version String?
  app_version String?
  ip_address String?
  last_seen_at DateTime?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([userId, device_id])
  @@index([userId])
  @@map("devices")
}

model user_link {
  id             String   @id @default(cuid())
  sourceUserId   String
  targetUserId   String
  source_user    user     @relation("source_user", fields: [sourceUserId], references: [id], onDelete: Cascade)
  target_user    user     @relation("target_user", fields: [targetUserId], references: [id], onDelete: Cascade)
  reason         String?
  confidence_score Float?
  created_by     String?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  @@unique([sourceUserId, targetUserId])
  @@index([sourceUserId])
  @@index([targetUserId])
  @@map("user_links")
}

model admin_action_log {
  id         String   @id @default(cuid())
  adminId    String?
  admin      user?    @relation("admin_actor", fields: [adminId], references: [id], onDelete: SetNull)
  action     String
  resource   String
  resource_id String?
  metadata   Json?
  created_at DateTime @default(now())

  @@index([adminId])
  @@index([resource])
  @@map("admin_action_logs")
}

model subscription {
  id          String              @id @default(cuid())
  userId      String
  user        user                @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan_name   String
  amount      Decimal             @db.Decimal(10, 2)
  status      subscription_status @default(pending)
  start_at    DateTime?
  end_at      DateTime?
  auto_renew  Boolean             @default(false)
  provider_ref String?
  created_at  DateTime            @default(now())
  updated_at  DateTime            @updatedAt

  @@index([userId])
  @@index([status])
  @@map("subscriptions")
}

model refund {
  id            String        @id @default(cuid())
  transactionId String
  transaction   transaction   @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  requesterId   String?
  requester     user?         @relation("refund_requested_by", fields: [requesterId], references: [id], onDelete: SetNull)
  amount        Float
  reason        String?
  status        refund_status @default(pending)
  processed_at  DateTime?
  failure_reason String?
  created_at    DateTime      @default(now())
  updated_at    DateTime      @updatedAt

  @@index([transactionId])
  @@index([status])
  @@map("refunds")
}

model notification_template {
  id         String               @id @default(cuid())
  name       String               @unique
  channel    notification_channel
  title      String
  body       String               @db.Text
  variables  Json?
  is_active  Boolean              @default(true)
  created_at DateTime             @default(now())
  updated_at DateTime             @updatedAt
  logs       notification_log[]

  @@map("notification_templates")
}

model notification_log {
  id          String               @id @default(cuid())
  templateId  String?
  template    notification_template? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  userId      String?
  user        user?                @relation("notification_recipient", fields: [userId], references: [id], onDelete: SetNull)
  channel     notification_channel
  target      notification_target
  status      status_type          @default(pending)
  message     String?              @db.Text
  variables   Json?
  error_message String?
  sent_at     DateTime?
  created_at  DateTime             @default(now())

  @@index([channel])
  @@index([status])
  @@map("notification_logs")
}

model gift_category {
  id          String  @id @default(cuid())
  name        String  @unique
  description String? @db.Text

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  gift       gift[]

  @@map("gift_category")
}

model gift {
  id          String        @id @default(cuid())
  points      Decimal       @db.Decimal(10, 2)
  category    gift_category @relation(fields: [gift_category_id], references: [id])
  name        String?
  description String?       @db.Text

  image   file?   @relation(fields: [imageId], references: [id])
  imageId String?

  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt
  gift_category_id String

  @@map("gifts")
}

model chat {
  id String @id @default(cuid())

  participants participant[]
  messages     message[]

  can_send_messages Boolean @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("chats")
}

model participant {
  id     String @id @default(cuid())
  chat   chat   @relation(fields: [chatId], references: [id], onDelete: Cascade)
  chatId String

  mute DateTime?

  user   user   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("participants")
}

model message {
  id   String       @id @default(cuid())
  type message_type

  content String? @db.Text
  edited  Boolean @default(false)
  deleted Boolean @default(false)

  file   file?   @relation(fields: [fileId], references: [id])
  fileId String?

  user   user?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  chat       chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  chatId     String

  @@map("messages")
}

model panic_actions {
  id        String  @id @default(cuid())
  latitude  Float
  longitude Float
  location  String?
  user      user    @relation(fields: [userId], references: [id])

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  userId     String
}

model notification {
  id      String            @id @default(cuid())
  title   String
  body    String?
  type    notification_type
  is_read Boolean           @default(false)
  user    user              @relation(fields: [userId], references: [id])
  userId  String

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("notifications")
}
